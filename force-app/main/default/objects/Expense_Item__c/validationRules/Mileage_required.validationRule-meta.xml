<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Mileage_required</fullName>
    <active>true</active>
    <description>Ensure mileage is provided for mileage expenses</description>
    <errorConditionFormula>ISPICKVAL(Type__c,&apos;Mileage&apos;) &amp;&amp; ISBLANK(Mileage__c)</errorConditionFormula>
    <errorDisplayField>Mileage__c</errorDisplayField>
    <errorMessage>Enter mileage field for mileage expenses</errorMessage>
</ValidationRule>

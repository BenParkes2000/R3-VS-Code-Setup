<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Account_must_match_project</fullName>
    <active>true</active>
    <errorConditionFormula>!ISBLANK(Project__c) &amp;&amp; !ISBLANK(Account__c) &amp;&amp; (Account__c !=   Project__r.Account__c) &amp;&amp; !ISCHANGED(Project__c)</errorConditionFormula>
    <errorMessage>Account must relate to the project!</errorMessage>
</ValidationRule>

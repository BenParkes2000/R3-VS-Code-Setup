<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Feedback_Type__c</fullName>
    <description>A field to record and display the type of UAT feedback item that provided.</description>
    <inlineHelpText>Please submit whether your UAT feedback item is an issue, a question or a change request.</inlineHelpText>
    <label>Type</label>
    <required>true</required>
    <trackFeedHistory>false</trackFeedHistory>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Issue</fullName>
                <default>true</default>
                <label>Issue</label>
            </value>
            <value>
                <fullName>Change Request (New Work Item)</fullName>
                <default>false</default>
                <label>Change Request (New Work Item)</label>
            </value>
            <value>
                <fullName>Question</fullName>
                <default>false</default>
                <label>Question</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>

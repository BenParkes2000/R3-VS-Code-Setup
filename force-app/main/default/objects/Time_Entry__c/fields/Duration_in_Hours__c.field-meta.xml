<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Duration_in_Hours__c</fullName>
    <description>How long the time entry was worked on for, converted into hours</description>
    <externalId>false</externalId>
    <formula>IF(FLOOR(MOD((Calculated_Stop__c-Start__c)* 24, 24 )) &gt; 0, TEXT(FLOOR(MOD((Calculated_Stop__c-Start__c)* 24, 24 ))) &amp; &quot; H &quot;,&quot;&quot;) 
 &amp; 
TEXT(ROUND(MOD((Calculated_Stop__c-Start__c)* 24 * 60, 60 ), 0)) &amp; &quot; M &quot;
 &amp; 
TEXT(ROUND(MOD((Calculated_Stop__c-Start__c)* 24 * 60*60, 60 ), 0)) &amp; &quot; S&quot;</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Duration in Hours</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
